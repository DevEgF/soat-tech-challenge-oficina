# Copy this file to .env and set your local values before running Docker Compose.
POSTGRES_DB=oficina
POSTGRES_USER=oficina
POSTGRES_PASSWORD=change-me-in-local-env

SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/oficina
SPRING_DATASOURCE_USERNAME=oficina
SPRING_DATASOURCE_PASSWORD=change-me-in-local-env

# Não defina SPRING_FLYWAY_ENABLED=false aqui: o perfil docker precisa do Flyway para criar o schema
# antes do JPA (ddl-auto=validate). O docker-compose.yml força SPRING_FLYWAY_ENABLED=true no serviço app.

# JWT HS256 (use segredo longo e aleatório em produção)
APP_JWT_SECRET=change-me-in-local-env-jwt-secret-min-32-chars-recommended

# Senha só do utilizador "admin". Os outros utilizadores em memória usam password = username:
# atendente/atendente, tecnico/tecnico, almoxarife/almoxarife.
# Usa "admin" em dev para coincidir com o Postman; em produção define um valor forte.
APP_SECURITY_ADMIN_PASSWORD=admin

# Se aparecer "Schema validation: missing table ..." após mudanças de migração, pode ser volume Postgres
# inconsistente. Recrie o volume e suba de novo: docker compose down -v && docker compose up --build -d
